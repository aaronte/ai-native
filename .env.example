# Web app — intake form + OAuth callback need DB + secrets when deployed.
APP_URL=http://localhost:8888

# Discord OAuth (intake → QR → authorize → callback links Discord user to prefilled session)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Optional — defaults to {APP_URL}/api/discord/callback (must match Developer Portal exactly)
# DISCORD_REDIRECT_URI=http://localhost:8888/api/discord/callback
# Optional: /installed-style deep link if you add that page back later
# DISCORD_BOT_USER_ID=

# Supabase Postgres — bot, drizzle-cli, and Next.js intake/OAuth linking (same schema)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# Optional: direct connection for drizzle-kit push if pooler fails on DDL
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# OpenRouter (coach + summarization on the bot host only)
OPENROUTER_API_KEY=
# Optional: OpenRouter model slugs — https://openrouter.ai/models
# OPENROUTER_COACH_MODEL=anthropic/claude-sonnet-4.6
# OPENROUTER_SUMMARY_MODEL=google/gemini-2.5-flash
# OPENROUTER_APP_NAME=
# OPENROUTER_APP_URL=

# Discord bot (gateway host: Railway, or local `npm run bot`)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
