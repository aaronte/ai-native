# Web (Vercel) + bot (Railway/Fly)
APP_URL=http://localhost:3000

# Supabase Postgres (transaction pooler URL, port 6543)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Optional: direct connection for drizzle-kit push if pooler fails on DDL
# DIRECT_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Anthropic (bot host — coach loop)
ANTHROPIC_API_KEY=

# Discord OAuth (web app)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord bot (gateway host only; optional on Vercel for DM deep link)
DISCORD_BOT_TOKEN=
DISCORD_APPLICATION_ID=
DISCORD_BOT_USER_ID=
